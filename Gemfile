source "https://rubygems.org"

# Mirrors the gems GitHub Pages uses to build the site, so you can preview
# locally with `bundle exec jekyll serve`. Not required to publish — GitHub
# Pages builds the site for you on push.
gem "github-pages", group: :jekyll_plugins

# Lock the http_parser gem for older Rubies (harmless on newer ones)
gem "webrick", "~> 1.8"
